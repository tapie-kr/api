model ApplyForm {
  id        Int            @id @default(autoincrement())
  name      String
  startsAt  DateTime
  endsAt    DateTime
  responses FormResponse[]
  createdAt DateTime       @default(now())
  Member    Member[]
  Asset     Asset?         @relation(fields: [assetUuid], references: [uuid])
  assetUuid String?
}

model FormResponse {
  uuid               String  @id @default(uuid())
  formId             Int
  memberUUID         String? @unique
  portfolioAssetUUID String? @unique

  name               String
  unit               MemberUnit
  googleEmail        String     @unique
  phoneNumber        String     @unique
  introduction       String
  motivation         String
  expectedActivities String
  reasonToChoose     String

  form      ApplyForm @relation(fields: [formId], references: [id])
  member    Member?   @relation(fields: [memberUUID], references: [uuid], onDelete: SetNull)
  portfolio Asset?    @relation(fields: [portfolioAssetUUID], references: [uuid], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
